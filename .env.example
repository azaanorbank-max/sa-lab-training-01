# Database
POSTGRES_DB=salab
POSTGRES_USER=salab
POSTGRES_PASSWORD=salab
DATABASE_URL=postgresql+asyncpg://salab:salab@postgres:5432/salab

# Service URLs (used inside Docker network)
DECISION_HUB_URL=http://decision-hub:8002
LEDGER_URL=http://ledger-mock:8003
PAYMENT_SERVICE_URL=http://payment-service:8001

# For local development outside Docker, override these:
# DATABASE_URL=postgresql+asyncpg://salab:salab@localhost:5432/salab
# DECISION_HUB_URL=http://localhost:8002
# LEDGER_URL=http://localhost:8003
# PAYMENT_SERVICE_URL=http://localhost:8001
